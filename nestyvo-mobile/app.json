{
  "expo": {
    "name": "Nestyvo",
    "slug": "nestyvo-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "nestyvo",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nestyvo.app"
    },
    "android": {
      "package": "com.nestyvo.app",
      "adaptiveIcon": {
        "backgroundColor": "#1D4ED8",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-font"
      ]
    ]
  }
}
